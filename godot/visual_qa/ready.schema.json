{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geometory.local/schemas/visual-qa-ready-v1.json",
  "title": "Geometory Visual QA Ready Marker",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "nonce",
    "scenario_id",
    "success",
    "errors",
    "assertions",
    "seed",
    "ui_scale",
    "safe_area_profile",
    "build_id",
    "viewport",
    "safe_area",
    "state_hash"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "nonce": { "type": "string", "pattern": "^[A-Za-z0-9_-]{8,64}$" },
    "scenario_id": { "type": "string", "minLength": 1, "maxLength": 64 },
    "success": { "type": "boolean" },
    "errors": { "type": "array", "items": { "type": "string" } },
    "assertions": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "seed": { "type": "integer", "minimum": 0, "maximum": 2147483647 },
    "ui_scale": { "enum": [1.0, 1.15, 1.3] },
    "safe_area_profile": { "enum": ["live", "galaxy_s24_primary"] },
    "build_id": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" },
    "viewport": { "$ref": "#/$defs/rect" },
    "safe_area": { "$ref": "#/$defs/rect" },
    "state_hash": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
  },
  "$defs": {
    "rect": {
      "type": "object",
      "additionalProperties": false,
      "required": ["x", "y", "width", "height"],
      "properties": {
        "x": { "type": "integer" },
        "y": { "type": "integer" },
        "width": { "type": "integer", "minimum": 0 },
        "height": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
